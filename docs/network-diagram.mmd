    Browser -->|"HTTPS :443\n/chat/* (no sub key)\n/openai/* (sub key)"| APIM

    APIM -->|"MI auth\n(Bearer token)"| PE_AIS
    PE_AIS -.->|"Private Link"| Foundry

    APIM -->|"VNet peering +\nPrivate DNS\n→ 10.1.2.4"| PE_CAE
    PE_CAE -.->|"Private Link"| ChatApp

    ChatApp -->|"APIM sub key\nPOST /openai/deployments/gpt-4o/\nchat/completions"| APIM

    ChatApp -.->|"AcrPull\n(Managed Identity)"| ACR

    PE_Storage -.->|"Private Link"| StorageAcct
    PE_Search -.->|"Private Link"| SearchSvc
    PE_Cosmos -.->|"Private Link"| CosmosAcct

    HubVNet <-->|"Bidirectional\nVNet Peering"| SpokeVNet

    DNS_CAE -.->|"*.env-prefix → 10.1.2.4"| PE_CAE

    APIM -->|"Logs + Metrics"| AppIns
    AppIns -->|"Workspace"| LAW
    CAE -->|"Container Logs"| LAW

