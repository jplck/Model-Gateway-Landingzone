                <mxCell id="sidecar-to-fic" value="" style="endArrow=blockThin;endFill=1;html=1;strokeColor=#7E57C2;strokeWidth=2;dashed=1;curved=1;" edge="1" parent="1" source="auth-sidecar" target="fic">
