                </mxCell>
                <mxCell id="setup-script" value="setup_agent_identity.sh  (Graph API)&#xa;Creates: Blueprint → SP → FIC → Agent Identity → RBAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0F0;strokeColor=#999999;fontSize=9;fontStyle=2;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="1226" y="970" width="330" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="spoke-storage-note" value="When enabled: Spoke Storage (agent-files) + list_files LangChain tool&#xa;Auth sidecar acquires Storage token → agent lists blobs via Azure REST API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0F0;strokeColor=#999999;fontSize=9;fontStyle=2;verticalAlign=middle;align=center;arcSize=8;" vertex="1" parent="1">
