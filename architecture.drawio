ainer Registry (ACR Tasks)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;Observability&lt;/td&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;Log Analytics + App Insights&lt;/td&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;(uses hub workspace)&lt;/td&gt;&lt;/tr&gt;&lt;tr style='background:#F5F5F5'&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;Private DNS&lt;/td&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;7 zones (linked to both VNets)&lt;/td&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;Agent Service&lt;/td&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;—&lt;/td&gt;&lt;td style='border:1px solid #999;padding:3px'&gt;Capability Host + gateway → APIM&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;spacingLeft=2;spacingRight=2;verticalAlign=top;" vertex="1" parent="1">
