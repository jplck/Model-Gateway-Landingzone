9;&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;ACR&lt;/td&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;—&lt;/td&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;Container Registry (ACR Tasks)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;Observability&lt;/td&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;Log Analytics + App Insights&lt;/td&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;(uses hub workspace)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&#39;background:#F5F5F5&#39;&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;Private DNS&lt;/td&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;7 zones (linked to both VNets)&lt;/td&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;Agent Service&lt;/td&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;—&lt;/td&gt;&lt;td style=&#39;border:1px solid #999;padding:3px&#39;&gt;Capability Host + gateway → APIM&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;spacingLeft=2;spacingRight=2;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="60" y="605" width="680" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="entra-section" value="Microsoft Entra ID — Agent Identity (Optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=5;dashed=1;dashPattern=5 5;arcSize=6;" vertex="1" parent="1">
                    <mxGeometry x="26" y="890" width="1560" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="token-flow" value="Token Flow:   Sidecar (uses MI)  →  FIC validates MI  →  Blueprint issues token  →  Agent Identity  →  Resource Token" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=6;fontColor=#5C6BC0;" vertex="1" parent="1">
                    <mxGeometry x="126" y="925" width="900" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="fic" value="❶ Federated Identity&#xa;Credential (FIC)&#xa;Registered on Blueprint&#xa;Trusts Container App MI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7986CB;strokeColor=#5C6BC0;fontColor=#FFFFFF;fontSize=9;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="66" y="970" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="blueprint" value="❷ Blueprint&#xa;(AgentIdentityBlueprint)&#xa;App Registration + SP&#xa;Issues token via FIC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5C6BC0;strokeColor=#3949AB;fontColor=#FFFFFF;fontSize=9;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="326" y="970" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="agent-identity" value="❸ Agent Identity&#xa;(Entra Service Principal)&#xa;RBAC: Storage Blob Contributor,&#xa;Cognitive Services User" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7E57C2;strokeColor=#5E35B1;fontColor=#FFFFFF;fontSize=9;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="586" y="970" width="230" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="agent-id-usecases" value="Use Cases:&#xa;• Autonomous — own security context, own RBAC roles&#xa;• On-Behalf-Of (Digital Colleague) — delegated permissions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0F0;strokeColor=#AAAAAA;fontSize=9;verticalAlign=middle;align=left;spacingLeft=10;arcSize=8;" vertex="1" parent="1">
