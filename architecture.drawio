                </mxCell>
                <mxCell id="sidecar-to-fic-label" value="Sidecar presents MI credential&#xa;FIC validates → Blueprint token&#xa;→ Agent Identity token" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=8;fontColor=#7E57C2;fontStyle=2;" connectable="0" vertex="1" parent="sidecar-to-fic">
